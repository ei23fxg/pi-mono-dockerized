#!/usr/bin/env bash

if [ -z "${BASH_VERSION:-}" ]; then
    echo "Error: This script requires bash. Please run with: bash $0" >&2
    exit 1
fi

set -euo pipefail

# --- Konfiguration ---
CURRENT_DIR_HASH=$(printf '%s' "$PWD" | md5sum | cut -d' ' -f1)
CURRENT_DIR_HASH_SHORT="${CURRENT_DIR_HASH: -6}"
PROJECT_NAME="$(basename "$(pwd)")"
PI_WORK_DIR="/${PROJECT_NAME}_${CURRENT_DIR_HASH_SHORT}"

PI_DOCKER_CONFIG_ROOT="$HOME/.pi"
PI_API_KEY_FILES=(ANTHROPIC_API_KEY OPENAI_API_KEY GEMINI_API_KEY GROQ_API_KEY XAI_API_KEY HF_TOKEN)
PI_CONTAINER_NAME_PREFIX="pi-"
PI_CONTAINER_NAME="${PI_CONTAINER_NAME_PREFIX}${CURRENT_DIR_HASH}"
PI_IMAGE_NAME="pi:latest"
PI_FOLDER="$HOME/.pi"
PI_GLOBAL_VOLUME="pi-global-packages"

PI_DEFAULT_IGNORED_FILES=(.env .deploy .secret .git .build .vscode .gitmodules .pi .aiignore .aiexclude .copilotignore .gitignore .geminiignore .codeiumignore .cursorignore .DS_Store)
PI_IGNORE_CONFIGS=(.aiignore .aiexclude .copilotignore .gitignore .geminiignore .codeiumignore .cursorignore)
PI_EMPTY_DIR=$(mktemp -d)

cleanup() {
    rm -rf "$PI_EMPTY_DIR" 2>/dev/null || true
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Helper: Docker Image bauen
# ---------------------------------------------------------------------------
build_image() {
    echo "Building pi base image (VM-Style)..."
    TEMP_BUILD_DIR=$(mktemp -d)
    cat > "${TEMP_BUILD_DIR}/Dockerfile" <<EOF
FROM node:bookworm

# System-Abhängigkeiten + Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl wget ffmpeg imagemagick jq make git ca-certificates \
    python3 python3-pip python3-venv python3-full \
    && rm -rf /var/lib/apt/lists/*

RUN ln -s /usr/bin/python3 /usr/bin/python

# UV GLOBAL
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh

# PERSISTENZ-KONFIGURATION
ENV NPM_CONFIG_PREFIX=/home/hostuser/.npm-global
ENV PYTHONUSERBASE=/home/hostuser/.python-local
ENV PATH="/home/hostuser/.npm-global/bin:/home/hostuser/.python-local/bin:/usr/local/bin:\${PATH}"
# Erlaubt dem Agenten pip installs in sein persistentes Verzeichnis
ENV PIP_USER=true

RUN mkdir -p /home/hostuser/.pi /home/hostuser/.npm-global /home/hostuser/.python-local \
    && chmod -R 777 /home/hostuser \
    && chmod 777 /
EOF
    docker build -t "${PI_IMAGE_NAME}" -f "${TEMP_BUILD_DIR}/Dockerfile" "${TEMP_BUILD_DIR}"
    rm -rf "${TEMP_BUILD_DIR}"
}

# ---------------------------------------------------------------------------
# Helper: Volume & Bootstrap
# ---------------------------------------------------------------------------
bootstrap_environment() {
    if [[ -z "$(docker images -q "${PI_IMAGE_NAME}" 2>/dev/null)" ]]; then
        build_image
    fi

    docker volume create "${PI_GLOBAL_VOLUME}" > /dev/null
    docker run --rm -v "${PI_GLOBAL_VOLUME}:/data" busybox chown -R "$(id -u):$(id -g)" /data

    # Check ob pi installiert ist
    if ! docker run --rm \
        --user "$(id -u):$(id -g)" \
        -v "${PI_GLOBAL_VOLUME}:/home/hostuser" \
        "${PI_IMAGE_NAME}" \
        ls /home/hostuser/.npm-global/bin/pi >/dev/null 2>&1; then
        
        echo "Initializing pi agent in volume..."
        docker run --rm \
            --user "$(id -u):$(id -g)" \
            -e HOME=/home/hostuser \
            -v "${PI_FOLDER}:/home/hostuser/.pi" \
            -v "${PI_GLOBAL_VOLUME}:/home/hostuser" \
            "${PI_IMAGE_NAME}" \
            /bin/sh -c "npm install -g @mariozechner/pi-coding-agent@latest @steipete/summarize@latest"
    fi
}

# ---------------------------------------------------------------------------
# Haupt-Ausführung
# ---------------------------------------------------------------------------
run_pi() {
    local mode="$1"
    shift
    
    bootstrap_environment
    mkdir -p "${PI_FOLDER}"

    DOCKER_ARGS=(
        --rm
        -it
        --user "$(id -u):$(id -g)"
        -e "HOME=/home/hostuser"
        -v "${PI_FOLDER}:/home/hostuser/.pi"
        # Wir mounten das gesamte Home-Unterverzeichnis für NPM und Python
        -v "${PI_GLOBAL_VOLUME}:/home/hostuser"
    )

    if [[ "$mode" == "project" ]]; then
        DOCKER_ARGS+=(--name "${PI_CONTAINER_NAME}")
        DOCKER_ARGS+=(-v "$(pwd):${PI_WORK_DIR}")
        DOCKER_ARGS+=(-e "PI_PROJECT_NAME=${PROJECT_NAME}")
        
        docker rm -f "${PI_CONTAINER_NAME}" 2>/dev/null || true

        for file in "${PI_DEFAULT_IGNORED_FILES[@]}"; do
            if [[ -d "./$file" ]]; then
                DOCKER_ARGS+=(-v "${PI_EMPTY_DIR}:${PI_WORK_DIR}/$file")
            elif [[ -f "./$file" ]]; then
                DOCKER_ARGS+=(-v "/dev/null:${PI_WORK_DIR}/$file")
            fi
        done

        for key in "${PI_API_KEY_FILES[@]}"; do
            key_file="${PI_DOCKER_CONFIG_ROOT}/$key"
            [[ -f "$key_file" ]] && DOCKER_ARGS+=(-e "$key=$(cat "$key_file")")
        done
        
        INNER_CMD="cd ${PI_WORK_DIR} && pi $*"
    else
        INNER_CMD="pi $*"
    fi

    # Starten mit kombiniertem Path für NPM und Python
    docker run "${DOCKER_ARGS[@]}" "${PI_IMAGE_NAME}" /bin/sh -c \
        "export PATH=/home/hostuser/.npm-global/bin:/home/hostuser/.python-local/bin:/usr/local/bin:\$PATH && $INNER_CMD"
}

# ===========================================================================
# Routing
# ===========================================================================

PI_COMMAND="${1:-}"

if [[ "${PI_COMMAND}" == "rebuild" ]]; then
    docker rmi "${PI_IMAGE_NAME}" 2>/dev/null || true
    shift
    PI_COMMAND="${1:-}"
fi

PI_CONFIG_COMMANDS="install remove uninstall update list config"
for cmd in $PI_CONFIG_COMMANDS; do
    if [[ "${PI_COMMAND}" == "$cmd" ]]; then
        run_pi "config" "$@"
        exit $?
    fi
done

run_pi "project" "$@"